# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=resumes

# JWT
JWT_SECRET_KEY=your-secret-key-change-this-in-production-at-least-32-characters-long
