# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=resumes

# Seed client company/user (first boot)
SEED_COMPANY_NAME=TalentVault Demo
SEED_COMPANY_SLUG=talentvault-demo
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@talentvault.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_ROLE=Admin
SEED_HR_NAME=HR User
SEED_HR_EMAIL=hr@talentvault.local
SEED_HR_PASSWORD=Hr123456!
SEED_HR_ROLE=HR

# JWT
JWT_SECRET_KEY=your-secret-key-change-this-in-production-at-least-32-characters-long
JWT_ISSUER=TalentVault
JWT_AUDIENCE=TalentVaultUsers
JWT_EXPIRATION_MINUTES=480

# Frontend -> API base URL used during Docker build/runtime
NEXT_PUBLIC_API_URL=http://localhost:5015/api/v1
